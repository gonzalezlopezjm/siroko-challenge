###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_to_a_random_32_char_string
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://siroko:siroko@postgres:5432/siroko?serverVersion=16&charset=utf8"
POSTGRES_DB=siroko
POSTGRES_USER=siroko
POSTGRES_PASSWORD=siroko
###< doctrine/doctrine-bundle ###

###> redis ###
REDIS_URL=redis://redis:6379
###< redis ###

###> qdrant ###
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=siroko_products
###< qdrant ###

###> embeddings (OpenAI) ###
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
###< embeddings ###

###> llm fallback (configurable: openai | anthropic) ###
# Dejar vacío para deshabilitar el fallback LLM silenciosamente
LANGUAGE_MODEL_PROVIDER=openai
LANGUAGE_MODEL_API_KEY=
LANGUAGE_MODEL_NAME=gpt-4o-mini
###< llm fallback ###

###> search ###
SEARCH_SIMILARITY_THRESHOLD=0.70
SEARCH_MAX_RESULTS=10
###< search ###

###> admin auth ###
ADMIN_API_KEY=change_me_to_a_secure_random_string
###< admin auth ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> symfony/messenger ###
# Por defecto usa Doctrine (tabla messenger_messages).
# Cambiar a redis://redis:6379/messages o amqp://... si se quiere broker externo.
# MESSENGER_TRANSPORT_DSN=doctrine://default?queue_name=async
###< symfony/messenger ###

###> symfony/mailer ###
MAILER_DSN=smtp://mailpit:1025
MAILER_FROM=noreply@siroko.com
###< symfony/mailer ###
