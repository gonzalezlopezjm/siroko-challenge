<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping
    xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                        https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Catalog\Infrastructure\Persistence\Model\ProductOrm" table="products">

        <id name="id" type="string" length="36" column="id">
            <generator strategy="NONE"/>
        </id>

        <field name="name"          type="string"  length="255"  column="name"           nullable="false"/>
        <field name="description"   type="text"                  column="description"    nullable="false"/>
        <field name="priceAmount"   type="integer"               column="price_amount"   nullable="false"/>
        <field name="priceCurrency" type="string"  length="3"    column="price_currency" nullable="false"/>
        <field name="category"      type="string"  length="50"   column="category"       nullable="false"/>
        <field name="brand"         type="string"  length="100"  column="brand"          nullable="false"/>
        <field name="attributes"    type="json"                  column="attributes"     nullable="false"/>
        <field name="stock"         type="integer"               column="stock"          nullable="false"/>
        <field name="imageUrl"      type="string"  length="2048" column="image_url"      nullable="true"/>
        <field name="createdAt"     type="datetime_immutable"    column="created_at"     nullable="false"/>
        <field name="updatedAt"     type="datetime_immutable"    column="updated_at"     nullable="false"/>

        <unique-constraints>
            <unique-constraint name="uq_product_name_category" columns="name,category"/>
        </unique-constraints>

    </entity>

</doctrine-mapping>
