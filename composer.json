{
    "name": "siroko/senior-challenge",
    "description": "Siroko Senior PHP Challenge — Catalog + Cart + Order + Semantic Search",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.3",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "doctrine/doctrine-bundle": "^2.12",
        "doctrine/doctrine-migrations-bundle": "^3.3",
        "doctrine/orm": "^3.2",
        "ramsey/uuid": "^4.7",
        "symfony/console": "7.*",
        "symfony/doctrine-messenger": "7.*",
        "symfony/dotenv": "7.*",
        "symfony/flex": "^2",
        "symfony/framework-bundle": "7.*",
        "symfony/http-client": "7.*",
        "symfony/mailer": "7.*",
        "symfony/messenger": "7.*",
        "symfony/runtime": "7.*",
        "symfony/security-bundle": "7.*",
        "symfony/serializer": "7.*",
        "symfony/validator": "7.*",
        "symfony/yaml": "7.*"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.11",
        "phpunit/phpunit": "^11.2",
        "symfony/browser-kit": "7.*",
        "symfony/css-selector": "7.*",
        "symfony/phpunit-bridge": "7.*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/",
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-install-cmd": [],
        "post-update-cmd": []
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.*"
        }
    }
}
